page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: scroll;
}
.profile-header {
  background: white;
  padding: 60rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.profile-header .avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
}
.profile-header .nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.profile-header .bio {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}
.content-list {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}
.content-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.content-item .info {
  flex: 1;
  margin-right: 16rpx;
}
.content-item .title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.content-item .summary {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}
.content-item .meta {
  font-size: 22rpx;
  color: #999;
}
.content-item .cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 8rpx;
}
.loading, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
