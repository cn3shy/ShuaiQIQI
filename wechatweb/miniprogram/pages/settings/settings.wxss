page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: scroll;
}
.menu-list {
  background: white;
  margin-top: 24rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item .label {
  font-size: 30rpx;
  color: #333;
}
.menu-item .arrow {
  font-size: 32rpx;
  color: #ccc;
}
.logout-btn-wrapper {
  padding: 32rpx;
}
.logout-btn {
  background: white;
  color: #ff4d4f;
  border-radius: 12rpx;
  font-size: 32rpx;
}
