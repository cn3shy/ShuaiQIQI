page {
  height: 100vh;
  background: #f5f5f5;
}
.login-container {
  padding: 60rpx 48rpx;
}
.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 80rpx;
  text-align: center;
}
.form {
  background: white;
  border-radius: 16rpx;
  padding: 48rpx;
}
.input {
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}
.btn {
  height: 96rpx;
  background: #1890ff;
  color: white;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.btn-wx {
  background: #07c160;
}
.register-link {
  text-align: center;
  font-size: 28rpx;
  color: #1890ff;
  margin-top: 16rpx;
}
