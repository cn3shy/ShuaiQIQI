page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: scroll;
}
.profile-header {
  background: white;
  padding: 60rpx 32rpx;
  display: flex;
  justify-content: center;
}
.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.user-info .avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
}
.user-info .nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}
.user-info .bio {
  font-size: 26rpx;
  color: #999;
}
.menu-list {
  background: white;
  margin-top: 24rpx;
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.menu-item .label {
  font-size: 30rpx;
  color: #333;
}
.menu-item .arrow {
  font-size: 32rpx;
  color: #ccc;
}
.login-btn-wrapper {
  padding: 32rpx;
}
.login-btn {
  background: #1890ff;
  color: white;
  border-radius: 12rpx;
  font-size: 32rpx;
}
