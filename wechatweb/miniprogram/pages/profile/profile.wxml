<scroll-view class="scrollarea" scroll-y type="list">
  <view class="profile-header">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl || defaultAvatarUrl}}"/>
      <text class="nickname">{{userInfo.nickName}}</text>
      <text class="bio" wx:if="{{userInfo.bio}}">{{userInfo.bio}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToMyContent">
      <text class="label">我的内容</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <text class="label">设置</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="login-btn-wrapper" wx:if="{{!isLogin}}">
    <button class="login-btn" bindtap="goToLogin">登录</button>
  </view>
</scroll-view>
