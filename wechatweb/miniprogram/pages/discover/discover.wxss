page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: scroll;
}
.content-list {
  padding: 24rpx;
}
.content-item {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.content-item .cover {
  width: 100%;
  height: 300rpx;
}
.content-item .info {
  padding: 24rpx;
}
.content-item .title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.content-item .summary {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}
.content-item .meta {
  font-size: 24rpx;
  color: #999;
  display: flex;
  justify-content: space-between;
}
.loading, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
