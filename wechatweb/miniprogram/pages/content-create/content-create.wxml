<view class="create-container">
  <view class="form">
    <view class="cover-section" bindtap="chooseImage">
      <image class="cover-preview" src="{{coverImage}}" mode="aspectFill" wx:if="{{coverImage}}"/>
      <view class="cover-placeholder" wx:else>
        <text class="plus">+</text>
        <text class="text">添加封面</text>
      </view>
    </view>
    <input class="input" placeholder="标题" bindinput="onTitleInput" value="{{title}}"/>
    <textarea class="textarea summary" placeholder="摘要（可选）" bindinput="onSummaryInput" value="{{summary}}"/>
    <textarea class="textarea content" placeholder="内容" bindinput="onContentInput" value="{{content}}"/>
    <button class="btn" bindtap="handleSubmit" loading="{{loading}}">发布</button>
  </view>
</view>
