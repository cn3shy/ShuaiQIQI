page {
  height: 100vh;
  background: #f5f5f5;
}
.create-container {
  padding: 32rpx;
}
.form {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
}
.cover-section {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  background: #f5f5f5;
}
.cover-preview {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.cover-placeholder .plus {
  font-size: 64rpx;
  color: #ccc;
}
.cover-placeholder .text {
  font-size: 28rpx;
  color: #999;
  margin-top: 16rpx;
}
.input {
  height: 96rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
}
.textarea {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  margin-bottom: 24rpx;
  width: 100%;
  box-sizing: border-box;
}
.summary {
  height: 120rpx;
}
.content {
  height: 400rpx;
}
.btn {
  height: 96rpx;
  background: #1890ff;
  color: white;
  border-radius: 12rpx;
  font-size: 32rpx;
}
