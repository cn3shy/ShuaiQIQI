page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}
.scrollarea {
  flex: 1;
  overflow-y: scroll;
}
.detail {
  background: white;
  padding-bottom: 32rpx;
}
.detail .cover {
  width: 100%;
  height: 400rpx;
}
.detail .header {
  padding: 32rpx;
}
.detail .title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}
.detail .author {
  display: flex;
  align-items: center;
}
.detail .author .avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.detail .author .name {
  font-size: 28rpx;
  color: #666;
}
.detail .body {
  padding: 0 32rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}
.detail .actions {
  display: flex;
  padding: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 32rpx;
}
.action-item {
  display: flex;
  align-items: center;
  margin-right: 48rpx;
}
.action-item .icon {
  font-size: 40rpx;
  margin-right: 8rpx;
}
.action-item .count {
  font-size: 28rpx;
  color: #666;
}
.comments {
  background: white;
  margin-top: 16rpx;
  padding: 32rpx;
}
.comment-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}
.comment-item {
  display: flex;
  margin-bottom: 24rpx;
}
.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}
.comment-content {
  flex: 1;
}
.comment-author {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}
.comment-text {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}
.comment-time {
  font-size: 22rpx;
  color: #999;
}
.loading, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 28rpx;
}
