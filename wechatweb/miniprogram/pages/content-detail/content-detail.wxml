<scroll-view class="scrollarea" scroll-y type="list" wx:if="{{content}}">
  <view class="detail">
    <image class="cover" src="{{content.coverImage}}" mode="aspectFill" wx:if="{{content.coverImage}}"/>
    <view class="header">
      <text class="title">{{content.title}}</text>
      <view class="author" bindtap="goToAuthor" data-userid="{{content.author.id}}">
        <image class="avatar" src="{{content.author.avatarUrl}}"/>
        <text class="name">{{content.author.nickName}}</text>
      </view>
    </view>
    <view class="body">
      <rich-text nodes="{{content.content}}"></rich-text>
    </view>
    <view class="actions">
      <view class="action-item" bindtap="onLike">
        <text class="icon">{{content.isLiked ? '❤️' : '🤍'}}</text>
        <text class="count">{{content.likeCount}}</text>
      </view>
      <view class="action-item" bindtap="onFavorite">
        <text class="icon">{{content.isFavorited ? '⭐' : '☆'}}</text>
        <text class="count">{{content.favoriteCount}}</text>
      </view>
    </view>
  </view>
  <view class="comments">
    <text class="comment-title">评论 ({{comments.length}})</text>
    <view class="comment-item" wx:for="{{comments}}" wx:key="id">
      <image class="comment-avatar" src="{{item.user.avatarUrl}}"/>
      <view class="comment-content">
        <text class="comment-author">{{item.user.nickName}}</text>
        <text class="comment-text">{{item.content}}</text>
        <text class="comment-time">{{item.createTime}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{comments.length === 0}}">暂无评论</view>
  </view>
</scroll-view>
<view class="loading" wx:if="{{loading}}">加载中...</view>
